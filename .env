# MySQL container
MYSQL_ROOT_PASSWORD=${DB_PASSWORD}
MYSQL_DATABASE=homerodoh
MYSQL_HOST_PORT=3307
MYSQL_CONTAINER_PORT=3306

# App container
APP_HOST_PORT=8080

# Spring Boot app (en Docker)
DB_URL_DOCKER=jdbc:mysql://mysql:3306/homerodoh?createDatabaseIfNotExist=true
DB_USERNAME=${DB_USERNAME}
DB_PASSWORD=${DB_PASSWORD}

# Seguridad JWT (minimo 32 caracteres)
JWT_SECRET=${JWT_SECRET}
